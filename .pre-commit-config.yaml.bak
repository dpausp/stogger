repos:
  # Local hooks using UV for individual tools
  - repo: local
    hooks:
      # Validation
      - id: validate-pyproject
        name: validate pyproject.toml
        entry: uv run validate-pyproject pyproject.toml
        language: system
        files: pyproject\.toml$
        pass_filenames: false

      # Formatting
      - id: # ruff-format
        name: # ruff format
        entry: uv run # ruff format
        language: system
        types: [python]
        require_serial: false

      - id: # ruff-check-fix
        name: # ruff check --fix
        entry: uv run # ruff check --fix
        language: system
        types: [python]
        require_serial: false

